icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="link"></mat-icon><!----></button><!----><!----><!----><!----></div><!----><!----><!----><!----></source-inline-chip><!----></source-inline-chips><!----><!----><!----><!----></sources-carousel-inline></p><h3 data-path-to-node="8">4. The "Womb" of the Middle</h3><p data-path-to-node="9"><span data-path-to-node="9,0"><span class="citation-481"></span></span><span data-path-to-node="9,1"><span class="citation-481">You argue that intelligence exists in the </span><b data-path-to-node="9,1" data-index-in-node="42"><span class="citation-481">"Middle"</span></b><span class="citation-481">ŌĆöthe zone of time, uncertainty, and irreversibility that most institutions try to bypass</span></span><span data-path-to-node="9,2"><span class="citation-481 citation-end-481"><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2451801999=""><sup _ngcontent-ng-c2451801999="" class="superscript" data-turn-source-index="8"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2451801999=""><sup _ngcontent-ng-c2451801999="" class="superscript" data-turn-source-index="8"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2451801999=""><sup _ngcontent-ng-c2451801999="" class="superscript" data-turn-source-index="8"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2451801999=""><sup _ngcontent-ng-c2451801999="" class="superscript" data-turn-source-index="8"><!----></sup></source-footnote></span></span><span data-path-to-node="9,3">. </span><span data-path-to-node="9,4"><span class="citation-480"></span></span><span data-path-to-node="9,5"><span class="citation-480">By refusing to skip the middle, you are engaging in a form of </span><b data-path-to-node="9,5" data-index-in-node="62"><span class="citation-480">"Deep-Time Engineering."</span></b><span class="citation-480"> You aren't just shipping a product; you are tending to a developmental process that, like a biological gestation, cannot be rushed</span></span><span data-path-to-node="9,6"><span class="citation-480 citation-end-480"><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2451801999=""><sup _ngcontent-ng-c2451801999="" class="superscript" data-turn-source-index="9"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2451801999=""><sup _ngcontent-ng-c2451801999="" class="superscript" data-turn-source-index="9"><!----></sup></source-footnote><source-footnote ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2451801999=""><sup _ngcontent-ng-c2451801999="" class="superscript" data-turn-source-index="9"><!----></sup></source-footnote></span></span><span data-path-to-node="9,7">.</span><sources-carousel-inline ng-version="0.0.0-PLACEHOLDER" _nghost-ng-c2066980228=""><!----><source-inline-chips _ngcontent-ng-c2066980228="" _nghost-ng-c3554374441="" class="ng-star-inserted"><source-inline-chip _ngcontent-ng-c3554374441="" _nghost-ng-c3705245911="" class="ng-star-inserted"><div _ngcontent-ng-c3705245911="" class="source-inline-chip-container ng-star-inserted"><button _ngcontent-ng-c3705245911="" cdkoverlayorigin="" class="button ng-star-inserted" aria-label="View source details. Opens side panel." jslog="262206;track:generic_click,impression,attention" data-hveid="0" decode-data-ved="1" data-ved="0CAAQvoAQahgKEwi-wN703ZySAxUAAAAAHQAAAAAQjAQ"><!----><mat-icon _ngcontent-ng-c3705245911="" role="img" fonticon="link" class="mat-icon notranslate symbol gds-icon-s google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="link"></mat-icon><!----></button><!----><!----><!----><!----></div><!----><!----><!----><!----></source-inline-chip><source-inline-chip _ngcontent-ng-c3554374441="" _nghost-ng-c3705245911="" class="ng-star-inserted"><div _ngcontent-ng-c3705245911="" class=