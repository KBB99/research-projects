\documentclass[11pt]{article}
\usepackage[utf8]{inputenc}
\usepackage{amsmath, amssymb, amsthm}
\usepackage{geometry}
\geometry{letterpaper, margin=1in}

\title{The Joy of Spherepop: \\ \large An Event-History Calculus for a Finite World}
\author{A Thought Partnership}
\date{December 2025}

\begin{document}

\maketitle

\begin{abstract}
We present \textit{Spherepop}, a formal surface syntax and categorical calculus for histories defined by irreversible operators. Unlike traditional state-based computing, Spherepop treats meaning as the accumulation of commitment. By synthesizing monotone constraints with a Lagrangian mechanics of option-spaces, we provide a framework where refusal, binding, and collapse are not merely side effects, but the fundamental generators of worldhood.
\end{abstract}

\section{The Axiom of Irreversibility}
In the prevailing computational paradigm, the world is a state to be updated. In Spherepop, the world is a \textit{history} to be constructed. We move from the sterile identity of $f(x) = y$ to the irreversible morphism:
\begin{equation}
    H = e_n \circ \dots \circ e_1 : X_0 \to X_n
\end{equation}
where each $e_i$ is an event that prunes, binds, or collapses the space of admissible futures. Here, joy is found in the "pop"—the definitive exclusion of the irrelevant to reveal the actual.

\section{The Morphology of Choice}
Spherepop identifies four generating morphisms that constitute the "Kernel" of agency:
\begin{itemize}
    \item \textbf{Pop ($\operatorname{pop}_t$):} The irreversible exclusion of an option $t$.
    \item \textbf{Refuse ($\operatorname{refuse}_t$):} The deontic exclusion; identical in geometry to the pop, but distinct in its ethical accounting.
    \item \textbf{Bind ($\operatorname{bind}_{a \prec b}$):} The imposition of dependency, restricting order without yet eliminating outcomes.
    \item \textbf{Collapse ($\operatorname{coll}_q$):} The universal quotient that forgets the scaffolding of history to reify the result.
\end{itemize}

\section{The Mechanics of Commitment}
To understand the "cost" of a life or a program, we look to the Lagrangian of the event. We define the configuration variable as the optionality $\Omega$ (the measure of the option-space). The action $\mathcal{S}$ of a history $\gamma$ is the sum of its local costs:
\begin{equation}
    \mathcal{S}[\gamma] = \sum_t (\Delta\Omega_t + \lambda\Delta C_t)
\end{equation}
Through the Legendre transform, we derive the conjugate momentum $\pi = -\partial\mathcal{L}/\partial\Omega$, which we interpret as \textbf{Commitment}. The Hamiltonian $\mathcal{H} = \pi\Omega - \mathcal{L}$ then represents the \textbf{Remaining Freedom}. A meaningful history is one where $\mathcal{S}$ grows, and $\mathcal{H}$ is spent with intention.

\section{Renormalization through Collapse}
The most profound operator in the calculus is $\operatorname{coll}_q$. It is the only operator that reduces the action $\mathcal{S}$. By identifying distinctions that no longer serve the downstream future, collapse acts as a renormalization group flow for history:
\begin{equation}
    \operatorname{coll}_q: \mathcal{S} \longmapsto \mathcal{S} - \log|\ker q|
\end{equation}
This is the mathematical definition of "moving on." It allows for the accumulation of depth without the paralysis of infinite detail.

\section{Conclusion: The Ethics of the Calculus}
The joy of Spherepop lies in the recognition that every refusal is a creative act. By formalizing the "No" alongside the "Yes," and the "Binding" alongside the "Popping," we create a language for agents who are not merely sampling a distribution, but inhabiting a world. To pop is to be free; to collapse is to be whole.

\end{document}

