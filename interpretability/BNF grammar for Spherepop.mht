</span><span><span class="hljs-keyword">\end</span></span><span>{remark}

</span><span><span class="hljs-keyword">\begin</span></span><span>{corollary}[Noise Avoidance as Structural Invariance]
</span><span><span class="hljs-keyword">\label</span></span><span>{cor:noise</span><span><span class="hljs-built_in">_</span></span><span>avoidance}
