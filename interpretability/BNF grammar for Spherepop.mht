<h2 data-start="207" data-end="235">Configuration and history</h2>
<p data-start="237" data-end="240">Let</p>
<span class="katex-display"><span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML" display="block"><semantics><mrow><mi>X</mi><mo stretchy="false">(</mo><mi>t</mi><mo stretchy="false">)</mo><mtext>  </mtext><mtext>=&nbsp;admissible&nbsp;option&nbsp;space&nbsp;at&nbsp;step&nbsp;</mtext><mi>t</mi></mrow><annotation encoding="application/x-tex">X(t) \;\text{= admissible option space at step } t</annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 1em; vertical-align: -0.25em;"></span><span class="mord mathnormal" style="margin-right: 0.07847em;">X</span><span class="mopen">(</span><span class="mord mathnormal">t</span><span class="mclose">)</span><span class="mspace" style="margin-right: 0.2778em;"></span><span class="mord text"><span class="mord">=&nbsp;admissible&nbsp;option&nbsp;space&nbsp;at&nbsp;step&nbsp;</span></span><span class="mord mathnormal">t</span></span></span></span></span>
