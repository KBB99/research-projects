</span><span><span class="hljs-keyword">\title</span></span><span>{The Narrow Path Between Domination and Chaos:</span><span><span class="hljs-keyword">\\</span></span><span>
Consent, Coordination, and Structural Control in the Age of Accelerating Intelligence}
</span><span><span class="hljs-keyword">\author</span></span><span>{Flyxion}
</span><span><span class="hljs-keyword">\date</span></span><span>{}

