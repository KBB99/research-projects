</ul>
<p data-start="4623" data-end="4631"><strong data-start="4623" data-end="4631">Cons</strong></p>
<ul data-start="4632" data-end="4705">
<li data-start="4632" data-end="4668">
<p data-start="4634" data-end="4668">Higher risk of subtle mis-emphasis</p>
</li>
<li data-start="4669" data-end="4705">
