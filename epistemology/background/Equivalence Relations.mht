&nbsp;&nbsp;&nbsp;&nbsp;if (take &gt; n) take = n;
&nbsp;&nbsp;&nbsp;&nbsp;memcpy(s-&gt;buf + s-&gt;buf_len, data, take);
&nbsp;&nbsp;&nbsp;&nbsp;s-&gt;buf_len += (unsigned int)take;
&nbsp;&nbsp;&nbsp;&nbsp;data += take;
&nbsp;&nbsp;&nbsp;&nbsp;n -= take;
&nbsp;&nbsp;&nbsp;&nbsp;if (s-&gt;buf_len == 64) {
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;sha1_block(s, s-&gt;buf);
