&nbsp;&nbsp;if (p-&gt;rx_len &lt; 2) return 0;</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">&nbsp;&nbsp;unsigned char b0 = p-&gt;rx[0];
