<span class="line"></span>
<span class="line"><span style="color: rgb(230, 230, 230);">where </span><span style="color: rgb(78, 201, 176);">$</span><span style="color: rgb(86, 156, 214);">\sigma</span><span style="color: rgb(78, 201, 176);">'</span><span style="color: rgb(78, 201, 176);">$</span><span style="color: rgb(230, 230, 230);"> differs from </span><span style="color: rgb(78, 201, 176);">$</span><span style="color: rgb(86, 156, 214);">\sigma</span><span style="color: rgb(78, 201, 176);">$</span><span style="color: rgb(230, 230, 230);"> only in </span><span style="color: rgb(78, 201, 176);">$</span><span style="color: rgb(78, 201, 176);">U</span><span style="color: rgb(78, 201, 176);">$</span><span style="color: rgb(230, 230, 230);">, with</span></span>
