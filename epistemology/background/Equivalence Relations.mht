<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">/* -------- Canonical event writing -------- */</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">static int write_event(FILE* f, const sp_event_hdr_t* hdr, const void* payload) {
&nbsp;&nbsp;if (fwrite(hdr, 1, sizeof(*hdr), f) != sizeof(*hdr)) return 0;
