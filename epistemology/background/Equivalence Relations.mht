<span class="line"><span style="color: rgb(220, 220, 170);">\frac</span><span style="color: rgb(230, 230, 230);">{</span></span>
<span class="line"><span style="color: rgb(230, 230, 230);">  o </span><span style="color: rgb(220, 220, 170);">\notin</span><span style="color: rgb(230, 230, 230);"> O</span></span>
<span class="line"><span style="color: rgb(230, 230, 230);">}{</span></span>
<span class="line"><span style="color: rgb(230, 230, 230);">  (O, U, R, M) </span><span style="color: rgb(220, 220, 170);">\xrightarrow</span><span style="color: rgb(230, 230, 230);">{</span><span style="color: rgb(220, 220, 170);">\mathrm</span><span style="color: rgb(230, 230, 230);">{POP}(o)} (O </span><span style="color: rgb(220, 220, 170);">\cup</span><span style="color: rgb(215, 186, 125);"> \{</span><span style="color: rgb(230, 230, 230);">o</span><span style="color: rgb(215, 186, 125);">\}</span><span style="color: rgb(230, 230, 230);">,</span><span style="color: rgb(220, 220, 170);">\;</span><span style="color: rgb(230, 230, 230);"> U[o </span><span style="color: rgb(220, 220, 170);">\mapsto</span><span style="color: rgb(230, 230, 230);"> o],</span><span style="color: rgb(220, 220, 170);">\;</span><span style="color: rgb(230, 230, 230);"> R,</span><span style="color: rgb(220, 220, 170);">\;</span><span style="color: rgb(230, 230, 230);"> M)</span></span>
