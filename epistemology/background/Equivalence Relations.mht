<span class="line"></span>
<span class="line"><span style="color: rgb(220, 220, 170);">\sigma</span><span style="color: rgb(220, 220, 170);"> \xrightarrow</span><span style="color: rgb(230, 230, 230);">{e} </span><span style="color: rgb(220, 220, 170);">\sigma</span><span style="color: rgb(230, 230, 230);">'</span></span>
<span class="line"></span>
