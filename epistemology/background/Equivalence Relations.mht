&nbsp;&nbsp;&nbsp;&nbsp;}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">&nbsp;&nbsp;&nbsp;&nbsp;sp_event_hdr_t hdr = {0};
&nbsp;&nbsp;&nbsp;&nbsp;hdr.eid = g_seq++;
