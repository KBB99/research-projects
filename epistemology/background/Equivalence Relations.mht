<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">&nbsp;&nbsp;if (p-&gt;rx_len &lt; off + (size_t)len) return 0;</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">&nbsp;&nbsp;if (opcode == 0x8) { /* close <span>*/
