<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">static int write_all(int fd, const void* buf, size_t len) {
&nbsp;&nbsp;const unsigned char* p = (const unsigned char*)buf;
&nbsp;&nbsp;size_t off = 0;
&nbsp;&nbsp;while (off &lt; len) {
&nbsp;&nbsp;&nbsp;&nbsp;ssize_t n = send(fd, p + off, len - off, 0);
&nbsp;&nbsp;&nbsp;&nbsp;if (n &lt; 0) {
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;if (errno == EINTR) continue;
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;if (errno == EAGAIN || errno == EWOULDBLOCK) return 0;
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;return -1;
&nbsp;&nbsp;&nbsp;&nbsp;}
&nbsp;&nbsp;&nbsp;&nbsp;off += (size_t)n;
&nbsp;&nbsp;}
&nbsp;&nbsp;return 1;
}</p>
