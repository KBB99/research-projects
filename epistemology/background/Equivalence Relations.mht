&nbsp;&nbsp;&nbsp;&nbsp;len = ((unsigned long long)p-&gt;rx[off] &lt;&lt; 8) | (unsigned long long)p-&gt;rx[off+1];
&nbsp;&nbsp;&nbsp;&nbsp;off += 2;
