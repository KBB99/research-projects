<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">"$@" &gt;"<span class="katex-error" title="ParseError: KaTeX parse error: Expected 'EOF', got '&amp;' at position 8: tmp&quot; 2&gt;&amp;╠▓1 || cmd_rc=" style="color: rgb(204, 0, 0);">tmp" 2&gt;&amp;1 || cmd_rc=</span>? || true
