<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-mode(1) ŌĆö mode selection with minimal output</p>
<p dir="auto" class="break-words"># POSIX shell.</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Usage:</p>
<p dir="auto" class="break-words"># sp-mode satire</p>
<p dir="auto" class="break-words"># sp-mode instrument</p>
<p dir="auto" class="break-words"># sp-mode --print</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Stores mode in ${SP_MODE_FILE:-$HOME/.config/spherepop/sp_mode}</p>
<p dir="auto" class="break-words"># Output is intentionally minimal.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">MODE_FILE=${SP_MODE_FILE:-"$HOME/.config/spherepop/sp_mode"}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">usage() {
&nbsp;&nbsp;cat &lt;&lt;'EOF'
Usage:
&nbsp;&nbsp;sp-mode satire|instrument
&nbsp;&nbsp;sp-mode --print</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Exit status:
&nbsp;&nbsp;0 on success
&nbsp;&nbsp;2 on usage error
EOF
}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">mkdir -p "$(dirname "$MODE_FILE")" 2&gt;/dev/null || true</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">if [ "${1:-}" = "--print" ]; then
&nbsp;&nbsp;if [ -f "$MODE_FILE" ]; then
&nbsp;&nbsp;&nbsp;&nbsp;mode=$(cat "$MODE_FILE" 2&gt;/dev/null || true)
&nbsp;&nbsp;&nbsp;&nbsp;if [ -n "${mode:-}" ]; then
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;printf 'Mode: %s\n' "$mode"
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;printf '%s\n' 'Constraints active: epistemic disclosure, non-claim enforcement'
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;exit 0
&nbsp;&nbsp;&nbsp;&nbsp;fi
&nbsp;&nbsp;fi
&nbsp;&nbsp;printf '%s\n' 'Mode: (unset)'
&nbsp;&nbsp;exit 0
fi</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">if [ $# -ne 1 ]; then
&nbsp;&nbsp;usage &gt;&amp;2
&nbsp;&nbsp;exit 2
fi</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">case "$1" in
&nbsp;&nbsp;satire|instrument)
&nbsp;&nbsp;&nbsp;&nbsp;printf '%s\n' "$1" &gt;"$MODE_FILE"
&nbsp;&nbsp;&nbsp;&nbsp;printf 'Mode: %s\n' "$1"
&nbsp;&nbsp;&nbsp;&nbsp;printf '%s\n' 'Constraints active: epistemic disclosure, non-claim enforcement'
&nbsp;&nbsp;&nbsp;&nbsp;;;
&nbsp;&nbsp;-h|--help)
&nbsp;&nbsp;&nbsp;&nbsp;usage
&nbsp;&nbsp;&nbsp;&nbsp;;;
&nbsp;&nbsp;*)
&nbsp;&nbsp;&nbsp;&nbsp;printf 'sp-mode: invalid mode: %s\n' "$1" &gt;&amp;2
&nbsp;&nbsp;&nbsp;&nbsp;usage &gt;&amp;2
&nbsp;&nbsp;&nbsp;&nbsp;exit 2
&nbsp;&nbsp;&nbsp;&nbsp;;;
esac</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-nonclaim(1) ŌĆö fail if claim-like language appears in text files</p>
<p dir="auto" class="break-words"># POSIX shell.</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Usage:</p>
<p dir="auto" class="break-words"># sp-nonclaim path [path ...]</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Behavior:</p>
<p dir="auto" class="break-words"># - Recurses into directories</p>
<p dir="auto" class="break-words"># - Scans regular files as text (best-effort)</p>
<p dir="auto" class="break-words"># - Flags lines containing forbidden claim-like phrases</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Exit status:</p>
<p dir="auto" class="break-words"># 0: no violations</p>
<p dir="auto" class="break-words"># 1: violations found</p>
<p dir="auto" class="break-words"># 2: usage error</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">usage() {
&nbsp;&nbsp;cat &lt;&lt;'EOF'
Usage:
&nbsp;&nbsp;sp-nonclaim PATH [PATH ...]</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Notes:
&nbsp;&nbsp;Recurses into directories and scans regular files.
&nbsp;&nbsp;Prints offending file:line:content entries.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Exit status:
&nbsp;&nbsp;0 no violations
&nbsp;&nbsp;1 violations found
&nbsp;&nbsp;2 usage error
EOF
}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">if [ $# -lt 1 ]; then
&nbsp;&nbsp;usage &gt;&amp;2
&nbsp;&nbsp;exit 2
fi</p>
<p dir="auto" class="break-words"># Forbidden phrases (case-insensitive). Keep small and explicit.</p>
<p dir="auto" class="break-words"># Extend via SP_NONCLAIM_RE if desired.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">DEFAULT_RE='(indicates|suggests|shows that|proves|detects|risk level|confidence)'
NONCLAIM_RE=${SP_NONCLAIM_RE:-$DEFAULT_RE}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">viol=0</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">scan_file() {
&nbsp;&nbsp;f=$1</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">&nbsp;&nbsp;# Skip obvious binaries (best-effort): if file has NUL byte, skip.
&nbsp;&nbsp;# POSIX: use awk to detect NUL via ORS hack is unreliable; use grep -Il where available.
&nbsp;&nbsp;# Fallback: attempt grep; if it errors, still try.
&nbsp;&nbsp;if command -v grep &gt;/dev/null 2&gt;&amp;1; then
&nbsp;&nbsp;&nbsp;&nbsp;# If grep supports -I, it treats binary as no match; if not, harmless.
&nbsp;&nbsp;&nbsp;&nbsp;:
&nbsp;&nbsp;fi</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">&nbsp;&nbsp;# Print file:line:content for matches.
&nbsp;&nbsp;# LC_ALL=C for predictable matching.
&nbsp;&nbsp;if LC_ALL=C grep -nEi "$NONCLAIM_RE" "$f" &gt;/dev/null 2&gt;&amp;1; then
&nbsp;&nbsp;&nbsp;&nbsp;LC_ALL=C grep -nEi "$NONCLAIM_RE" "$f" | sed "s|^|$f:|"
&nbsp;&nbsp;&nbsp;&nbsp;viol=1
&nbsp;&nbsp;fi
}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">scan_path() {
&nbsp;&nbsp;p=$1
&nbsp;&nbsp;if [ -d "$p" ]; then
&nbsp;&nbsp;&nbsp;&nbsp;# Find regular files; avoid following symlinks.
&nbsp;&nbsp;&nbsp;&nbsp;# POSIX find.
&nbsp;&nbsp;&nbsp;&nbsp;find "$p" -type f -print 2&gt;/dev/null | while IFS= read -r f; do
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;scan_file "$f"
&nbsp;&nbsp;&nbsp;&nbsp;done
&nbsp;&nbsp;elif [ -f "$p" ]; then
&nbsp;&nbsp;&nbsp;&nbsp;scan_file "$p"
&nbsp;&nbsp;else
&nbsp;&nbsp;&nbsp;&nbsp;printf 'sp-nonclaim: not found: %s\n' "$p" &gt;&amp;2
&nbsp;&nbsp;&nbsp;&nbsp;viol=1
&nbsp;&nbsp;fi
}</p>
<p dir="auto" class="break-words"># We need viol updated across subshells. Avoid pipe subshell by collecting file list first.</p>
<p dir="auto" class="break-words"># For directories, iterate with find output using command substitution (may be large; acceptable for repo-scale).</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">for p in "$@"; do
&nbsp;&nbsp;if [ -d "$p" ]; then
&nbsp;&nbsp;&nbsp;&nbsp;files=$(find "$p" -type f -print 2&gt;/dev/null || true)
&nbsp;&nbsp;&nbsp;&nbsp;if [ -n "$files" ]; then
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;# shellcheck disable=SC2086
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;for f in $files; do
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;scan_file "$f"
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;done
&nbsp;&nbsp;&nbsp;&nbsp;fi
&nbsp;&nbsp;elif [ -f "$p" ]; then
&nbsp;&nbsp;&nbsp;&nbsp;scan_file "$p"
&nbsp;&nbsp;else
&nbsp;&nbsp;&nbsp;&nbsp;printf 'sp-nonclaim: not found: %s\n' "$p" &gt;&amp;2
&nbsp;&nbsp;&nbsp;&nbsp;viol=1
&nbsp;&nbsp;fi
done</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">if [ "$viol" -ne 0 ]; then
&nbsp;&nbsp;exit 1
fi
exit 0</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-verify-silence(1) ŌĆö run a command and fail if its output contains claim-like language</p>
<p dir="auto" class="break-words"># POSIX shell.</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Usage:</p>
<p dir="auto" class="break-words"># sp-verify-silence -- command [args...]</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Behavior:</p>
<p dir="auto" class="break-words"># - Captures stdout+stderr</p>
<p dir="auto" class="break-words"># - Fails if forbidden phrases appear</p>
<p dir="auto" class="break-words"># - Replays captured output to original streams on success (and optionally on failure)</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Exit status:</p>
<p dir="auto" class="break-words"># 0: command ran, no forbidden phrases found</p>
<p dir="auto" class="break-words"># 1: forbidden phrases found</p>
<p dir="auto" class="break-words"># 2: usage error</p>
<p dir="auto" class="break-words"># 3: command failed (but no forbidden phrases)</p>
<p dir="auto" class="break-words"># </p>
<p dir="auto" class="break-words"># Environment:</p>
<p dir="auto" class="break-words"># SP_NONCLAIM_RE  override forbidden regex (egrep syntax)</p>
<p dir="auto" class="break-words"># SP_ECHO_ON_FAIL if "1", echo output even on failure</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">usage() {
&nbsp;&nbsp;cat &lt;&lt;'EOF'
Usage:
&nbsp;&nbsp;sp-verify-silence -- COMMAND [ARGS...]</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Exit status:
&nbsp;&nbsp;0 ok
&nbsp;&nbsp;1 forbidden phrases found in output
