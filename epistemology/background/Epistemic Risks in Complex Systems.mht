<p dir="auto" class="break-words"># Check output for forbidden phrases.</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">if [ -s "$tmp" ] &amp;&amp; LC_ALL=C grep -Ei "$NONCLAIM_RE" "$tmp" &gt;/dev/null 2&gt;&amp;1; then
