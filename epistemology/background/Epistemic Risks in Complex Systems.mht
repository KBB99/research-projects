&nbsp;&nbsp;"nodes": [
&nbsp;&nbsp;&nbsp;&nbsp;{
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"name": "laptop",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"host": "localhost",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"user": "flyxion",
