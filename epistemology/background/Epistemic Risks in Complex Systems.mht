&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"user": "flyxion",
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"roles": ["compute"]
&nbsp;&nbsp;&nbsp;&nbsp;}
&nbsp;&nbsp;]
}</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">No discovery. No guessing.
If itŌĆÖs not listed, it doesnŌĆÖt exist.</p>
<hr>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Example Tools (POSIX Bash)</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">sp-edge-init</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-edge-init ŌĆö initialize an explicit edge network</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">CONFIG="${1:-nodes/lab.json}"</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">if [ ! -f "$CONFIG" ]; then
&nbsp;&nbsp;echo "Config not found: $CONFIG" &gt;&amp;2
&nbsp;&nbsp;exit 1
fi</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">mkdir -p state
echo "Initialized edge network from $CONFIG"</p>
<hr>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">sp-edge-list</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-edge-list ŌĆö list declared edge nodes</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">CONFIG="${1:-nodes/lab.json}"</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">jq -r '.nodes[] | "(.name)\t(.user)@(.host)\t(.roles | join(","))"' "$CONFIG"</p>
<hr>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">sp-edge-run</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-edge-run ŌĆö run a command on all declared nodes</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">CMD="$*"
CONFIG="nodes/lab.json"</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">jq -r '.nodes[] | "(.user)@(.host)"' "$CONFIG" |
while read -r TARGET; do
&nbsp;&nbsp;echo "==&gt; $TARGET"
&nbsp;&nbsp;ssh "$TARGET" "$CMD"
done</p>
<hr>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">sp-edge-watch</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-edge-watch ŌĆö observe node availability (non-intrusive)</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">CONFIG="nodes/lab.json"</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">while true; do
&nbsp;&nbsp;date
&nbsp;&nbsp;jq -r '.nodes[] | "(.user)@(.host)"' "$CONFIG" |
&nbsp;&nbsp;while read -r TARGET; do
&nbsp;&nbsp;&nbsp;&nbsp;if ssh -o BatchMode=yes -o ConnectTimeout=2 "$TARGET" true 2&gt;/dev/null; then
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;echo "$TARGET: reachable"
&nbsp;&nbsp;&nbsp;&nbsp;else
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;echo "$TARGET: unavailable"
&nbsp;&nbsp;&nbsp;&nbsp;fi
&nbsp;&nbsp;done
&nbsp;&nbsp;sleep 10
done</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Observation only. No retries, no escalation.</p>
<hr>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">Coordinated Experiments</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">sp-edge-lab</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">#!/bin/sh</p>
<p dir="auto" class="break-words"># sp-edge-lab ŌĆö run a named experiment across nodes</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">set -eu</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">EXPERIMENT="$1"
SCRIPT="experiments/$EXPERIMENT.sh"</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">if [ ! -x "$SCRIPT" ]; then
&nbsp;&nbsp;echo "Experiment not found or not executable: $SCRIPT" &gt;&amp;2
&nbsp;&nbsp;exit 1
fi</p>
<p dir="auto" class="break-words" node="[object Object]" style="white-space: pre-wrap;">sp-edge-run "bash -s" &lt; "$SCRIPT"</p>
<hr>
