#!/usr/bin/env bash
set -euo pipefail
MODE="${1:-normal}"
LOGFILE="${2:-/tmp/spherepop.log}"

printf "\033[2J\033[H"
printf "SPHEREPOP STATUS BUS  ::  mode=%s  ::  log=%s\n" "$MODE" "$LOGFILE"
printf "------------------------------------------------------------\n"
while true; do
	uptime 2>/dev/null || true
	printf "kernel: "; uname -sr 2>/dev/null || true
	printf "time:   "; date
	printf "note:   refusal=exogenous  didacticity=risk  metrics=contaminants\n"
	printf "------------------------------------------------------------\n"
	sleep 2
done

