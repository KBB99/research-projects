#!/usr/bin/env bash
set -euo pipefail
MODE="${1:-normal}"
LOGFILE="${2:-/tmp/spherepop.log}"

mkdir -p "$(dirname "$LOGFILE")" 2>/dev/null || true
touch "$LOGFILE" 2>/dev/null || true

emit() {
	printf "%s spherepop[%d]: %s\n" "$(date '+%b %d %H:%M:%S')" "$$" "$*" >>"$LOGFILE" 2>/dev/null || true
}

emit "boot: mode=$MODE semantic_bus=online"
while true; do
	case $((RANDOM % 6)) in
		0) emit "probe: invariants=check result=pass";;
		1) emit "probe: didacticity=rise hint=compressive_pressure";;
		2) emit "probe: metric=stabilized risk=goodhart";;
		3) emit "probe: refusal=external veto=armed";;
		4) emit "probe: apprenticeship=pipeline_thin warning=fragility";;
		5) emit "probe: constraint_erasure=suspected channel=interface";;
	esac
	sleep $(( (RANDOM % 4) + 1 ))
done

