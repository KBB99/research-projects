#!/usr/bin/env bash
set -euo pipefail
MODE="${1:-normal}"
LOGFILE="${2:-/tmp/spherepop.log}"

while true; do
	n=$(( (RANDOM % 7) + 3 ))
	printf "drift: Δ=%d  invariant-check=%s  goodhart=%s\n" \
		"$n" \
		"$([ $((RANDOM%2)) -eq 0 ] && echo PASS || echo WARN)" \
		"$([ $((RANDOM%2)) -eq 0 ] && echo LOW || echo HIGH)"
	sleep 1
done

