#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/sp_common.sh"

TARGET=${1:-.}

log "Scanning semantic surface of $TARGET"

find "$TARGET" -type f \( -name "*.sp" -o -name "*.log" \) | while read -r f; do
  echo "FILE: $f"
  grep -E "POP|MERGE|LINK|COLLAPSE|REFUSE" "$f" | sed 's/^/  /'
done

log "Scan complete (surface only; no execution)"

