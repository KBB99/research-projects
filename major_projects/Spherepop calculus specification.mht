OrExpr    ::= AndExpr { "||" AndExpr } ;
AndExpr   ::= RelExpr { "&amp;&amp;" RelExpr } ;
RelExpr   ::= AddExpr [ ("==" | "!=" | "&lt;" | "&gt;" | "&lt;=" | "&gt;=") AddExpr ] ;
AddExpr   ::= MulExpr { ("+" | "-") MulExpr } ;
MulExpr   ::= Atom { ("*" | "/") Atom } ;

Atom      ::= Ident
            | IntLit
            | StringLit
            | BoolLit
            | RecordExpr
            | "(" Expr ")" ;

RecordExpr ::= "{" RecordField { "," RecordField } "}" ;

RecordField ::= Ident "=" Expr ;
</span></code></div></div></pre>
