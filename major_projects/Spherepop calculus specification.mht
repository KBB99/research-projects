| env (Expr.RFunExpr.linear e) :=
  match eval_aexpr env e with
  | some (Value.real v) := 
       some (λ t : Time, v * (t - 0))   -- NOTE: where is t0 used? see PopExpr below
  | _ := none
  end
| env (Expr.RFunExpr.poly coeffs) :=
  let vals := coeffs.map (eval_aexpr env) in
  if vals.all option.isSome then
    let cs := vals.map option.get! in
    some (λ t : Time, cs.enum.map (λ ⟨i,c⟩, c * t^i) |&gt;.sum)
  else none
| env (Expr.RFunExpr.wave ω k φ) :=
  match eval_aexpr env ω, eval_aexpr env k, eval_aexpr env φ with
  | some (Value.real ωr), some (Value.real kr), some (Value.real φr) :=
      some (λ t, kr * Real.sin (ωr * t + φr))
  | _,_,_ := none
  end
| env (Expr.RFunExpr.custom _) := none  -- excluded for deterministic core
</span></code></div></div></pre>
