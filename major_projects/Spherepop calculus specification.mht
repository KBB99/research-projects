open SpherePop SpherePop.Utils Expr

/-- Colors of the operad = modes. -/
abbrev Color := Mode

/-- An n-ary SpherePop operation. -/
structure Operation where
  inputs  : List Color
  output  : Color
  data    : Type  -- e.g., PopParam or merge metadata

/-- The operad structure. -/
structure Operad where
  op      : ℕ → Type     -- n-ary operations
  color   : op 0 → Color -- color of nullary ops (pops)
  comp    : ∀ {n m} (f : op n) (g : op m) (i : Fin n), op (n + m - 1)
  symm    : ∀ {n}, op n → Perm n → op n

/-- The SpherePop operad. -/
structure SpherePopOperad extends Operad :=
  (merge_op : PopParam → PopParam → PopParam)

/-- Interpretation of SpherePop processes as operad operations. -/
def interp : Expr.Process → SpherePopOperad → Type
| Expr.Process.nil, _ =&gt; PUnit
| Expr.Process.emit pe, O =&gt; O.op 0
| Expr.Process.par P Q, O =&gt; interp P O × interp Q O
| Expr.Process.seq P Q, O =&gt; unit  -- composition case; fill later
| Expr.Process.iff b P Q, O =&gt; Sum (interp P O) (interp Q O)
| Expr.Process.fixp X P, O =&gt; unit -- recursive case placeholder
| Expr.Process.pvar X, O =&gt; unit

end SpherePop.Operad
</span></code></div></div></pre>
