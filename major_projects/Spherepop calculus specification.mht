-- Files bundled below. Paste each section into the indicated file path in your project.

--------------------------------------------------------------------------------
-- lakefile.lean
--------------------------------------------------------------------------------
import Lake
open Lake DSL

package «spherepop» {}

lean_lib SpherePop

--------------------------------------------------------------------------------
-- src/SpherePop/Utils.lean
--------------------------------------------------------------------------------
/-- Utilities and minimal concrete definitions used across the core files.
    This file provides small, compilation-friendly placeholders for names that
    were abstract in the spec (Var, PVar, Point, Time, Mode, Value, Env).
    Replace with more precise definitions as you develop the mechanization. -/

namespace SpherePop.Utils

/-- Simple identifier types for the core development. -/
abbrev Var  := String
abbrev PVar := String

instance : DecidableEq Var := inferInstance
instance : DecidableEq PVar := inferInstance

/-- Minimal concrete geometric / temporal types for experimenting. -/
/-- Points are 2D pairs here for convenience; replace with ℝ^n when you link
    with a numeric or mathlib environment. -/
abbrev Point := Float × Float
abbrev Time  := Float

/-- Mode as a simple string tag in the core. -/
abbrev Mode := String

/-- Value and environment (simple). Value is a floating point scalar for now.
    Later you may want sums for points, reals, booleans, etc. -/
abbrev Value := Float
abbrev Env := Var → Option Value

/-- Convenience: empty environment. -/
def empty_env : Env := fun _ =&gt; none

end SpherePop.Utils

--------------------------------------------------------------------------------
-- src/SpherePop/Core.lean
--------------------------------------------------------------------------------
import SpherePop.Utils

/- Core, normalized SpherePop calculus -/

namespace SpherePop

open SpherePop.Utils

universe u

/-- Pop parameter record (semantic object). -/
structure PopParam where
  center : Point
  start  : Time
  radius : Time → Float
  amp    : Time → Float
  mode   : Mode
  deriving Inhabited

/-- Finite multiset representation (list). -/
abbrev PopStore := List PopParam

namespace Expr

abbrev Var  := SpherePop.Utils.Var
abbrev PVar := SpherePop.Utils.PVar

inductive AExpr : Type u
| var  : Var → AExpr
| real : Float → AExpr
| add  : AExpr → AExpr → AExpr

inductive BExpr : Type u
| eq : AExpr → AExpr → BExpr

structure PopExpr where
  center_e : AExpr
  t0_e     : AExpr
  rfun_e   : AExpr
  amp_e    : AExpr
  mode_e   : AExpr

inductive Process : Type u
| nil    : Process
| emit   : PopExpr → Process
| par    : Process → Process → Process
| seq    : Process → Process → Process
| let_in : Var → AExpr → Process → Process
| iff    : BExpr → Process → Process → Process
| fixp   : PVar → Process → Process
| pvar   : PVar → Process

end Expr

open Expr

/-- Substitution &amp; evaluator stubs are kept abstract in Core; evals live in
    <code>SpherePop.Eval</code>. We declare the names here so Core refers to them. -/

open SpherePop.Utils (Value Env)

/-- Substitution placeholders (to be implemented more precisely in later files). -/
constant subst_proc : Expr.Var → Value → Expr.Process → Expr.Process
constant subst_pvar : Expr.PVar → Expr.Process → Expr.Process → Expr.Process

/-- Predicates representing total deterministic evaluators on well-typed inputs.
    These are abstract in Core; the Eval module provides concrete stubs. -/
constant eval_popexpr_holds : Env → Expr.PopExpr → PopParam → Prop
constant eval_bexpr_true  : Env → Expr.BExpr → Prop
constant eval_bexpr_false : Env → Expr.BExpr → Prop
constant eval_aexpr_val   : Env → Expr.AExpr → Value → Prop

/-- Structural congruence -/
inductive cong : Expr.Process → Expr.Process → Prop
| par_comm {P Q} : cong (Process.par P Q) (Process.par Q P)
| par_assoc {P Q R} : cong (Process.par (Process.par P Q) R) (Process.par P (Process.par Q R))
| par_id {P} : cong (Process.par P Process.nil) P
| seq_assoc {P Q R} : cong (Process.seq (Process.seq P Q) R) (Process.seq P (Process.seq Q R))
| seq_id {P} : cong (Process.seq Process.nil P) P
| fix_unfold {X P} : cong (Process.fixp X P) (subst_pvar X (Process.fixp X P) P)

/-- Equivalence closure of structural congruence. -/
inductive cong_equiv : Expr.Process → Expr.Process → Prop
| base {P Q} : cong P Q → cong_equiv P Q
| refl {P}    : cong_equiv P P
| symm {P Q}  : cong_equiv P Q → cong_equiv Q P
| trans {P Q R} : cong_equiv P Q → cong_equiv Q R → cong_equiv P R

/-- Configurations and labels -/
inductive Label
| tau : Label
| emit_lbl : PopParam → Label

structure Config where
  proc : Expr.Process
  pops : PopStore

/-- Base reduction relation (no congruence). -/
inductive step (env : Env) : Config → Label → Config → Prop
| pop_emit {pe Π p} :
    eval_popexpr_holds env pe p →
    step env { proc := Process.emit pe, pops := Π } (Label.emit_lbl p)
              { proc := Process.nil, pops := Π ++ [p] }

| seq_left {P P' Q Π Π' α} :
    step env { proc := P, pops := Π } α { proc := P', pops := Π' } →
    step env { proc := Process.seq P Q, pops := Π } α { proc := Process.seq P' Q, pops := Π' }

| seq_complete {Q Π} :
    step env { proc := Process.seq Process.nil Q, pops := Π } Label.tau { proc := Q, pops := Π }

| par_left {P P' Q Π Π' α} :
    step env { proc := P, pops := Π } α { proc := P', pops := Π' } →
    step env { proc := Process.par P Q, pops := Π } α { proc := Process.par P' Q, pops := Π' }

| par_right {P Q Q' Π Π' α} :
    step env { proc := Q, pops := Π } α { proc := Q', pops := Π' } →
    step env { proc := Process.par P Q, pops := Π } α { proc := Process.par P Q', pops := Π' }

| if_true {b P Q Π} :
    eval_bexpr_true env b →
    step env { proc := Process.iff b P Q, pops := Π } Label.tau { proc := P, pops := Π }

| if_false {b P Q Π} :
    eval_bexpr_false env b →
    step env { proc := Process.iff b P Q, pops := Π } Label.tau { proc := Q, pops := Π }

| let_step {x e P Π v} :
    eval_aexpr_val env e v →
    step env { proc := Process.let_in x e P, pops := Π } Label.tau { proc := subst_proc x v P, pops := Π }

| fix_step {X P Π} :
    step env { proc := Process.fixp X P, pops := Π } Label.tau { proc := subst_pvar X (Process.fixp X P) P, pops := Π }

/-- Step modulo structural congruence. -/
inductive step_mod (env : Env) : Config → Label → Config → Prop
| mk {P1 P2 P2' P1' Π Π' α} :
    cong_equiv P1 P2 →
    step env { proc := P2, pops := Π } α { proc := P2', pops := Π' } →
    cong_equiv P2' P1' →
    step_mod env { proc := P1, pops := Π } α { proc := P1', pops := Π' }

/-- Reflexive–transitive closure (unlabelled) -/
inductive step_star (env : Env) : Config → Config → Prop
| refl {C} : step_star env C C
| trans {C1 C2 C3 α} :
    step_mod env C1 α C2 →
    step_star env C2 C3 →
    step_star env C1 C3

/-- Typing (minimal) -/
inductive Type
| Real : Type
| ProcT : Type
| PopParamT : Type

structure Context where
  vars  : Expr.Var → Option Type
  pvars : Expr.PVar → Option Type

inductive has_type_a : Context → Expr.AExpr → Type → Prop
| ty_real {Γ r} : has_type_a Γ (Expr.AExpr.real r) Type.Real

inductive has_type_b : Context → Expr.BExpr → Prop
| ty_eq {Γ e1 e2} : has_type_a Γ e1 Type.Real → has_type_a Γ e2 Type.Real → has_type_b Γ (Expr.BExpr.eq e1 e2)

inductive has_type_pop : Context → Expr.PopExpr → Prop
| pop {Γ c t r a m} :
    has_type_a Γ c Type.Real →
    has_type_a Γ t Type.Real →
    has_type_a Γ r Type.Real →
    has_type_a Γ a Type.Real →
    has_type_a Γ m Type.Real →
    has_type_pop Γ (Expr.PopExpr.mk c t r a m)

inductive has_type_proc : Context → Expr.Process → Prop
| ty_nil {Γ} : has_type_proc Γ Expr.Process.nil
| ty_emit {Γ pe} : has_type_pop Γ pe → has_type_proc Γ (Expr.Process.emit pe)
| ty_par {Γ P Q} : has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.par P Q)
| ty_seq {Γ P Q} : has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.seq P Q)
| ty_if {Γ b P Q} : has_type_b Γ b → has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.iff b P Q)
| ty_let {Γ x e P} : has_type_a Γ e Type.Real → has_type_proc Γ P → has_type_proc Γ (Expr.Process.let_in x e P)
| ty_fix {Γ X P} : has_type_proc (Context.mk Γ.vars (fun pv =&gt; if pv = X then some Type.ProcT else Γ.pvars pv)) P → has_type_proc Γ (Expr.Process.fixp X P)
| ty_pvar {Γ X} : Γ.pvars X = some Type.ProcT → has_type_proc Γ (Expr.Process.pvar X)

/-- Semantic well-formedness of PopParam. -/
def well_typed_pop (p : PopParam) : Prop :=
  ∀ t, 0 ≤ p.radius t

/-- Well-typed configuration: process well-typed and all pops well-formed. -/
def well_typed_config (Γ : Context) (cfg : Config) : Prop :=
  has_type_proc Γ cfg.proc ∧ cfg.pops.all (fun p =&gt; well_typed_pop p)

/-- Meta-theorems (statements only). -/
theorem preservation (env : Env) {Γ : Context} {C C' : Config} {α : Label} (hwf : well_typed_config Γ C) (hst : step_mod env C α C') : well_typed_config Γ C' := by admit

theorem progress (env : Env) {Γ : Context} {C : Config} (hwf : well_typed_config Γ C) (closed : True) : (∃ P', cong_equiv C.proc P' ∧ P' = Expr.Process.nil) ∨ (∃ α C', step_mod env C α C') := by admit

end SpherePop

