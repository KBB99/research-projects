7 6.136 4.40303 6.07083 4.80371 6.03809C5.14051 6.01057 5.53708 6.00551 6.00391 6.00391C6.00551 5.53708 6.01057 5.14051 6.03809 4.80371C6.0755 4.34588 6.15483 3.94012 6.34668 3.56348L6.46875 3.34473C6.77282 2.84912 7.20856 2.44514 7.72949 2.17969L7.87207 2.11328C8.20855 1.96886 8.56979 1.90385 8.9707 1.87109C9.42091 1.83432 9.978 1.83496 10.667 1.83496H13.5C14.1891 1.83496 14.746 1.83431 15.1963 1.87109C15.6541 1.90851 16.0599 1.98788 16.4365 2.17969L16.6553 2.30176C17.151 2.60585 17.5548 3.04244 17.8203 3.56348L17.8867 3.70606C18.031 4.04235 18.0962 4.40306 18.1289 4.80371C18.1657 5.25395 18.165 5.81091 18.165 6.5V9.33301Z"></path></svg>Copy code</button></div></div></div><div class="overflow-y-auto p-4" dir="ltr"><code class="whitespace-pre! language-lean"><span>/-- Small-step relation on configurations, with an explicit environment. -/
inductive step (env : Env) : Config → Label → Config → Prop
open Expr

-- POP-EMIT: pop expression evaluates to a concrete PopParam
| pop_emit {pe Π p} :
    eval_popexpr env pe = some p →
    step env ⟨Process.emit pe, Π⟩ (Label.emit_lbl p)
              ⟨Process.nil, Π ++ [p]⟩

-- SEQ-LEFT: reduce left of a sequence
| seq_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Process.seq P Q, Π⟩ α
             ⟨Process.seq P' Q, Π'⟩

-- SEQ-COMPLETE: when left is nil, drop it
| seq_complete {Q Π} :
    step env ⟨Process.seq Process.nil Q, Π⟩ Label.tau
             ⟨Q, Π⟩

-- PAR-L: reduce left in parallel
| par_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Process.par P Q, Π⟩ α
             ⟨Process.par P' Q, Π'⟩

-- PAR-R: reduce right in parallel
| par_right {P Q Q' Π Π' α} :
    step env ⟨Q, Π⟩ α ⟨Q', Π'⟩ →
    step env ⟨Process.par P Q, Π⟩ α
             ⟨Process.par P Q', Π'⟩

-- IF-TRUE: eval_bexpr = some tt
| if_true {b P Q Π} (h : eval_bexpr env b = some tt) :
    step env ⟨Process.iff b P Q, Π⟩ Label.tau
             ⟨P, Π⟩

-- IF-FALSE: eval_bexpr = some ff
| if_false {b P Q Π} (h : eval_bexpr env b = some ff) :
    step env ⟨Process.iff b P Q, Π⟩ Label.tau
             ⟨Q, Π⟩

-- LET: eval_aexpr = some v
| let_step {x e P Π v} (hev : eval_aexpr env e = some v) :
    step env ⟨Process.let_in x e P, Π⟩ Label.tau
             ⟨subst_proc x v P, Π⟩

-- FIX: one-step unfolding
| fix_step {X P Π} :
    step env ⟨Process.fixp X P, Π⟩ Label.tau
             ⟨subst_pvar X (Process.fixp X P) P, Π⟩

-- CONG-L / CONG-R: step is closed under structural congruence
| cong_left  {P P' Π α Π'} (h : cong P P') :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨P, Π⟩ α ⟨P', Π'⟩
| cong_right {P Π α P' Π'} (h : cong P P') :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨P, Π⟩ α ⟨P', Π'⟩
</span></code></div></div></pre>
<blockquote data-start="4241" data-end="4521">
<p data-start="4243" data-end="4521"><strong data-start="4243" data-end="4252">Note:</strong> the <code data-start="4257" data-end="4274">cong_left/right</code> rules above are schematic; in a real Lean development you’d likely define <em data-start="4349" data-end="4378">reduction modulo congruence</em> using a quotient type, or explicitly write:<br data-start="4422" data-end="4425">
if <code data-start="4430" data-end="4441">cong P P₁</code>, <code data-start="4443" data-end="4472">step env ⟨P₁, Π⟩ α ⟨P₂, Π'⟩</code>, <code data-start="4474" data-end="4486">cong P₂ P'</code> then <code data-start="4492" data-end="4520">step env ⟨P, Π⟩ α ⟨P', Π'⟩</code>.</p>
</blockquote>
<p data-start="4523" data-end="4608">For the spec, the key idea is: <strong data-start="4554" data-end="4607">stepping is invariant under structural congruence</strong>.</p>
<hr data-start="4610" data-end="4613">
<h2 data-start="4615" data-end="4653">4. Multi-step Semantics <code data-start="4642" data-end="4653">step_star</code></h2>
