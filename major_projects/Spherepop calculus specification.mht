7 6.136 4.40303 6.07083 4.80371 6.03809C5.14051 6.01057 5.53708 6.00551 6.00391 6.00391C6.00551 5.53708 6.01057 5.14051 6.03809 4.80371C6.0755 4.34588 6.15483 3.94012 6.34668 3.56348L6.46875 3.34473C6.77282 2.84912 7.20856 2.44514 7.72949 2.17969L7.87207 2.11328C8.20855 1.96886 8.56979 1.90385 8.9707 1.87109C9.42091 1.83432 9.978 1.83496 10.667 1.83496H13.5C14.1891 1.83496 14.746 1.83431 15.1963 1.87109C15.6541 1.90851 16.0599 1.98788 16.4365 2.17969L16.6553 2.30176C17.151 2.60585 17.5548 3.04244 17.8203 3.56348L17.8867 3.70606C18.031 4.04235 18.0962 4.40306 18.1289 4.80371C18.1657 5.25395 18.165 5.81091 18.165 6.5V9.33301Z"></path></svg>Copy code</button></div></div></div><div class="overflow-y-auto p-4" dir="ltr"><code class="whitespace-pre! language-lean"><span>inductive has_type_proc : Context → Expr.Process → Type → Prop
| ty_nil  {Γ} :
    has_type_proc Γ Expr.Process.nil Type.ProcT
| ty_emit {Γ pe} :
    has_type_pop Γ pe Type.PopParamT →
    has_type_proc Γ (Expr.Process.emit pe) Type.ProcT
| ty_par  {Γ P Q} :
    has_type_proc Γ P Type.ProcT →
    has_type_proc Γ Q Type.ProcT →
    has_type_proc Γ (Expr.Process.par P Q) Type.ProcT
| ty_seq  {Γ P Q} :
    has_type_proc Γ P Type.ProcT →
    has_type_proc Γ Q Type.ProcT →
    has_type_proc Γ (Expr.Process.seq P Q) Type.ProcT
| ty_if   {Γ b P Q} :
    has_type_bexpr Γ b →            -- you’d define this similarly to has_type_a
    has_type_proc Γ P Type.ProcT →
    has_type_proc Γ Q Type.ProcT →
    has_type_proc Γ (Expr.Process.iff b P Q) Type.ProcT
| ty_let  {Γ x e τ P} :
    has_type_a Γ e τ →
    has_type_proc (extend Γ x τ) P Type.ProcT → -- extend context on x
    has_type_proc Γ (Expr.Process.let_in x e P) Type.ProcT
| ty_fix  {Γ X P} :
    has_type_proc (extend_pvar Γ X Type.ProcT) P Type.ProcT →
    has_type_proc Γ (Expr.Process.fixp X P) Type.ProcT
| ty_pvar {Γ X} :
    -- if you track process-vars in the context
    lookup_pvar Γ X = some Type.ProcT →
    has_type_proc Γ (Expr.Process.pvar X) Type.ProcT
</span></code></div></div></pre>
<p data-start="6636" data-end="6692">This is schematic but enough to state the meta-theorems.</p>
