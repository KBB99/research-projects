| env pe :=
  match eval_aexpr env pe.center_e,
        eval_aexpr env pe.t0_e,
        eval_rfunexpr env pe.rfun_e,
        eval_ampexpr env pe.amp_e,
        eval_modeexpr env pe.mode_e with
  | some (Value.point c),
    some (Value.real t0),
    some rfun,
    some amp,
    some μ :=
      some {
        center := c,
        start := t0,
        radius := rfun,
        amp := amp,
        mode := μ
      }
  | _,_,_,_,_ := none
  end
</span></code></div></div></pre>
