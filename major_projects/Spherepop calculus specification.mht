7 6.136 4.40303 6.07083 4.80371 6.03809C5.14051 6.01057 5.53708 6.00551 6.00391 6.00391C6.00551 5.53708 6.01057 5.14051 6.03809 4.80371C6.0755 4.34588 6.15483 3.94012 6.34668 3.56348L6.46875 3.34473C6.77282 2.84912 7.20856 2.44514 7.72949 2.17969L7.87207 2.11328C8.20855 1.96886 8.56979 1.90385 8.9707 1.87109C9.42091 1.83432 9.978 1.83496 10.667 1.83496H13.5C14.1891 1.83496 14.746 1.83431 15.1963 1.87109C15.6541 1.90851 16.0599 1.98788 16.4365 2.17969L16.6553 2.30176C17.151 2.60585 17.5548 3.04244 17.8203 3.56348L17.8867 3.70606C18.031 4.04235 18.0962 4.40306 18.1289 4.80371C18.1657 5.25395 18.165 5.81091 18.165 6.5V9.33301Z"></path></svg>Copy code</button></div></div></div><div class="overflow-y-auto p-4" dir="ltr"><code class="whitespace-pre! language-lean"><span>def eval_aexpr : Env → Expr.AExpr → option Value
| env (Expr.AExpr.var x) := some (env x)
| env (Expr.AExpr.real r) := some (Value.real r)
| env (Expr.AExpr.point_const p) := some (Value.point p)
| env (Expr.AExpr.add e1 e2) :=
  match eval_aexpr env e1, eval_aexpr env e2 with
  | some (Value.real r1), some (Value.real r2) := some (Value.real (r1 + r2))
  | _, _ := none
  end
| env (Expr.AExpr.sub e1 e2) :=
  match eval_aexpr env e1, eval_aexpr env e2 with
  | some (Value.real r1), some (Value.real r2) := some (Value.real (r1 - r2))
  | _, _ := none
  end
| env (Expr.AExpr.mul e1 e2) :=
  match eval_aexpr env e1, eval_aexpr env e2 with
  | some (Value.real r1), some (Value.real r2) := some (Value.real (r1 * r2))
  | _, _ := none
  end
| env (Expr.AExpr.norm e) :=
  match eval_aexpr env e with
  | some (Value.point p) := some (Value.real (norm p))  -- requires norm : Point → ℝ
  | _ := none
  end
| env (Expr.AExpr.lam_t _) := none  -- excluded for determinism
</span></code></div></div></pre>
<p data-start="3056" data-end="3254"><strong data-start="3056" data-end="3077">Why drop <code data-start="3067" data-end="3074">lam_t</code>?</strong><br data-start="3077" data-end="3080">
Executable Lean cannot evaluate arbitrary real-valued symbolic lambdas without a DSL; we can reintroduce them once you choose a representation (piecewise, polynomials, etc.).</p>
