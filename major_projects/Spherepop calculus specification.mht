| par_comm  {P Q} :
    cong (Expr.Process.par P Q) (Expr.Process.par Q P)
| par_assoc {P Q R} :
    cong (Expr.Process.par (Expr.Process.par P Q) R)
         (Expr.Process.par P (Expr.Process.par Q R))
| par_id    {P} :
    cong (Expr.Process.par P Expr.Process.nil) P
| seq_assoc {P Q R} :
    cong (Expr.Process.seq (Expr.Process.seq P Q) R)
         (Expr.Process.seq P (Expr.Process.seq Q R))
| seq_id    {P} :
    cong (Expr.Process.seq Expr.Process.nil P) P
| fix_unfold {X P} :
    cong (Expr.Process.fixp X P)
         (subst_pvar X (Expr.Process.fixp X P) P)
| alpha_equiv {P Q} (h : P = Q) :
    cong P Q
</span></code></div></div></pre>
