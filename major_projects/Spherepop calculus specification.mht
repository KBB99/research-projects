84 9.99963C11.4984 10.827 10.8277 11.4985 10.0003 11.4987C9.17283 11.4987 8.50131 10.8271 8.50131 9.99963C8.50149 9.17228 9.17294 8.50159 10.0003 8.50159Z"></path></svg></button></div></div></div></div></article><article class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-(--header-height)" tabindex="-1" dir="auto" data-turn-id="bbb215da-0125-4c61-86e5-9bdba1a43d92" data-testid="conversation-turn-11" data-scroll-anchor="false" data-turn="user"><h5 class="sr-only">You said:</h5><div class="text-base my-auto mx-auto pt-12 [--thread-content-margin:--spacing(4)] thread-sm:[--thread-content-margin:--spacing(6)] thread-lg:[--thread-content-margin:--spacing(16)] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] thread-lg:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col" tabindex="-1"><div class="flex max-w-full flex-col grow"><div data-message-author-role="user" data-message-id="bbb215da-0125-4c61-86e5-9bdba1a43d92" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/1.1 relative rounded-[18px] px-4 py-1.5 data-[multiline]:py-3 max-w-[var(--user-chat-width,70%)]" data-multiline=""><div class="whitespace-pre-wrap">-- SpherePop Calculus — Lean-style formalization (refined)
-- Refined from the earlier sketch: this file provides a single-file Lean-style
-- specification with concrete small-step semantics (no placeholders), structural
-- congruence, step_star, well-typed configurations, and theorem statements for
-- Preservation and Progress. Evaluation functions (eval_aexpr, eval_bexpr,
-- eval_popexpr) are assumed total &amp; deterministic on well-typed closed inputs.

/- 0. Preamble and notes -/
-- This is a specification-style Lean file suitable for mechanization. Proofs
-- are left as <code>sorry</code> placeholders where indicated. The goal is to be a
-- drop-in starting point for Lean 4 development.

universe u

/-- Primitive domains &amp; basic semantic objects. -/
constant Point : Type u
constant Time  : Type u

def RFun := Time → ℝ

def Amp  := Time → ℝ

constant Mode : Type u
constant mode_star : Mode → Mode → Mode
constant mode_one  : Mode

constant Φ0 : Point → Time → ℝ

/-- Pop parameter record. -/
structure PopParam :=
(center : Point)
(start  : Time)
(radius : RFun)
(amp    : Amp)
(mode   : Mode)

/-- Pop store represented as finite list (multiset semantics). -/
def PopStore := List PopParam

/-- Shell contribution (distributional / symbolic). -/
constant shell_contrib : PopParam → Point → Time → ℝ

/-- Configuration: process + popstore. -/
structure Config :=
(proc : Expr.Process)
(pops : PopStore)

/-- Induced (denotational) field of a popstore. -/
def induced_field (Π : PopStore) : Point → Time → ℝ :=
λ x t, Φ0 x t + (Π.bind (λ p =&gt; [shell_contrib p x t])).foldl (fun acc v =&gt; acc + v) 0

/-----------------------------------------------------------------------------
  Syntax layer (expressions and processes) — kept in namespace Expr to avoid
  pollution. This reuses the earlier inductive BNF but is presented here
  compactly for a Lean file.
-------------------------------------------------------------------------------/

namespace Expr

constant Var  : Type u
constant PVar : Type u

inductive AExpr : Type u
| var  : Var → AExpr
| real : ℝ → AExpr
| point_const : Point → AExpr
| add  : AExpr → AExpr → AExpr
| sub  : AExpr → AExpr → AExpr
| mul  : AExpr → AExpr → AExpr
| norm : AExpr → AExpr
| lam_t : (Time → AExpr) → AExpr -- schematic; treated abstractly

inductive BExpr : Type u
| eq  : AExpr → AExpr → BExpr
| lt  : AExpr → AExpr → BExpr
| gt  : AExpr → AExpr → BExpr
| and : BExpr → BExpr → BExpr
| or  : BExpr → BExpr → BExpr
| not : BExpr → BExpr

inductive RFunExpr : Type u
| linear : AExpr → RFunExpr
| poly   : List AExpr → RFunExpr
| wave   : AExpr → AExpr → AExpr → RFunExpr
| custom : (Time → AExpr) → RFunExpr

inductive AmpExpr : Type u
| const : AExpr → AmpExpr
| decay : AExpr → AmpExpr
| pulse : AExpr → AExpr → AmpExpr
| custom : (Time → AExpr) → AmpExpr

inductive ModeExpr : Type u
| fundamental : ModeExpr
| harmonic   : AExpr → ModeExpr
| chirped    : ModeExpr
| custom     : AExpr → ModeExpr

structure PopExpr :=
(center_e : AExpr)
(t0_e     : AExpr)
(rfun_e   : RFunExpr)
(amp_e    : AmpExpr)
(mode_e   : ModeExpr)

/-- Process syntax (BNF). -/
inductive Process : Type u
| nil    : Process
| emit   : PopExpr → Process            -- pop(PopExpr)
| par    : Process → Process → Process  -- P | Q
| seq    : Process → Process → Process  -- P ; Q
| let_in : Var → AExpr → Process → Process
| iff    : BExpr → Process → Process → Process
| fixp   : PVar → Process → Process
| pvar   : PVar → Process

end Expr

/-----------------------------------------------------------------------------
  Structural congruence (≡) with fixpoint unfolding substitution
-------------------------------------------------------------------------------/
open Expr

/-- capture-avoiding substitution of a process variable (schematic). -/
constant subst_pvar : PVar → Expr.Process → Expr.Process → Expr.Process

inductive cong : Expr.Process → Expr.Process → Prop
| par_comm  {P Q} : cong (Expr.Process.par P Q) (Expr.Process.par Q P)
| par_assoc {P Q R} : cong (Expr.Process.par (Expr.Process.par P Q) R)
                                  (Expr.Process.par P (Expr.Process.par Q R))
| par_id    {P} : cong (Expr.Process.par P Expr.Process.nil) P
| seq_assoc {P Q R} : cong (Expr.Process.seq (Expr.Process.seq P Q) R)
                                  (Expr.Process.seq P (Expr.Process.seq Q R))
| seq_id    {P} : cong (Expr.Process.seq Expr.Process.nil P) P
| fix_unfold {X P} : cong (Expr.Process.fixp X P)
                          (subst_pvar X (Expr.Process.fixp X P) P)
| alpha_equiv {P Q} (h : P = Q) : cong P Q

/-- Congruence equivalence relation: reflexive-transitive-symmetric closure of cong.
    In a mechanization you typically define the quotient; here we just provide the
    relation symbolically. -/
constant cong_equiv : Expr.Process → Expr.Process → Prop

/-----------------------------------------------------------------------------
  Environment, values, and assumed evaluators (Option A existence assumption)
-------------------------------------------------------------------------------/

def Value :=
  (real_val : ℝ) -- schematic; real and point values can be encoded / extended

def Env := Expr.Var → Value

/-- Total deterministic evaluators on well-typed closed inputs (assumed). -/
constant eval_aexpr   : Env → Expr.AExpr → Option Value
constant eval_bexpr   : Env → Expr.BExpr → Option Bool
constant eval_popexpr : Env → Expr.PopExpr → Option PopParam

/-----------------------------------------------------------------------------
  Labels and configurations
-------------------------------------------------------------------------------/
inductive Label : Type u
| tau : Label
| emit_lbl : PopParam → Label

structure Config :=
(proc : Expr.Process)
(pops : PopStore)

/-----------------------------------------------------------------------------
  Small-step semantics (total, with cong closure rules sketched)
-------------------------------------------------------------------------------/

/-- Small-step reduction relation parameterized by environment. -/
inductive step (env : Env) : Config → Label → Config → Prop

-- POP-EMIT
| pop_emit {pe Π p} :
    eval_popexpr env pe = some p →
    step env ⟨Expr.Process.emit pe, Π⟩ (Label.emit_lbl p) ⟨Expr.Process.nil, Π ++ [p]⟩

-- SEQ-LEFT
| seq_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Expr.Process.seq P Q, Π⟩ α ⟨Expr.Process.seq P' Q, Π'⟩

-- SEQ-COMPLETE
| seq_complete {Q Π} :
    step env ⟨Expr.Process.seq Expr.Process.nil Q, Π⟩ Label.tau ⟨Q, Π⟩

-- PAR-L
| par_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Expr.Process.par P Q, Π⟩ α ⟨Expr.Process.par P' Q, Π'⟩

-- PAR-R
| par_right {P Q Q' Π Π' α} :
    step env ⟨Q, Π⟩ α ⟨Q', Π'⟩ →
    step env ⟨Expr.Process.par P Q, Π⟩ α ⟨Expr.Process.par P Q', Π'⟩

-- IF-TRUE / IF-FALSE
| if_true {b P Q Π} (h : eval_bexpr env b = some true) :
    step env ⟨Expr.Process.iff b P Q, Π⟩ Label.tau ⟨P, Π⟩
| if_false {b P Q Π} (h : eval_bexpr env b = some false) :
    step env ⟨Expr.Process.iff b P Q, Π⟩ Label.tau ⟨Q, Π⟩

-- LET
| let_step {x e P Π v} (hev : eval_aexpr env e = some v) :
    step env ⟨Expr.Process.let_in x e P, Π⟩ Label.tau ⟨(subst_proc x v P), Π⟩

-- FIX
| fix_step {X P Π} :
    step env ⟨Expr.Process.fixp X P, Π⟩ Label.tau ⟨(subst_pvar X (Expr.Process.fixp X P) P), Π⟩

-- CONG-MOD (schematic: reduction closed under cong_equiv)
| cong_mod {P1 P2 cfg2 α cfg2' P2'}
    (h₁ : cong_equiv P1 P2)
    (h₂ : step env ⟨P2, cfg2.pops⟩ α ⟨P2', cfg2'.pops⟩)
    (h₃ : cong_equiv P2' P2') :
    step env ⟨P1, cfg2.pops⟩ α ⟨P2', cfg2'.pops⟩

/-- Note: <code>cong_mod</code> above is schematic; in practice one proves that reduction is
    well-defined modulo cong and works with representatives or uses quotient types.
-/

/-----------------------------------------------------------------------------
  Reflexive–transitive closure (unlabelled) — <code>step_star</code>. We fold labels away
  for this relation (trace variants are similar but keep labels). -/
-------------------------------------------------------------------------------/
inductive step_star (env : Env) : Config → Config → Prop
| refl {C} : step_star env C C
| trans {C1 C2 C3 α} : step env C1 α C2 → step_star env C2 C3 → step_star env C1 C3

/-----------------------------------------------------------------------------
  Typing: simple typed grammar &amp; well-typed configurations
-------------------------------------------------------------------------------/
inductive Type : Type u
| Real : Type
| PointT : Type
| RFunT : Type
| AmpT  : Type
| ModeT : Type
| PopParamT : Type
| ProcT : Type

structure Context :=
(vars : Expr.Var → Option Type)
(pvars : Expr.PVar → Option Type) -- process-vars typing

/-- Typing judgments for expressions and processes (sketch). -/
inductive has_type_a : Context → Expr.AExpr → Type → Prop
| ty_real {Γ r} : has_type_a Γ (Expr.AExpr.real r) Type.Real
| ty_point {Γ p} : has_type_a Γ (Expr.AExpr.point_const p) Type.PointT
| ty_add {Γ e1 e2} : has_type_a Γ e1 Type.Real → has_type_a Γ e2 Type.Real → has_type_a Γ (Expr.AExpr.add e1 e2) Type.Real

inductive has_type_b : Context → Expr.BExpr → Prop
| ty_eq {Γ e1 e2} : has_type_a Γ e1 Type.Real → has_type_a Γ e2 Type.Real → has_type_b Γ (Expr.BExpr.eq e1 e2)

inductive has_type_rfun : Context → Expr.RFunExpr → Prop
| r_linear {Γ e} : has_type_a Γ e Type.Real → has_type_rfun Γ (Expr.RFunExpr.linear e)

inductive has_type_amp : Context → Expr.AmpExpr → Prop
| amp_const {Γ e} : has_type_a Γ e Type.Real → has_type_amp Γ (Expr.AmpExpr.const e)

inductive has_type_mode : Context → Expr.ModeExpr → Prop
| mode_fund {Γ} : has_type_mode Γ Expr.ModeExpr.fundamental

inductive has_type_pop : Context → Expr.PopExpr → Prop
| pop_typing {Γ c t rf af me} :
    has_type_a Γ c Type.PointT →
    has_type_a Γ t Type.Real →
    has_type_rfun Γ rf →
    has_type_amp Γ af →
    has_type_mode Γ me →
    has_type_pop Γ (Expr.PopExpr.mk c t rf af me)

inductive has_type_proc : Context → Expr.Process → Prop
| ty_nil  {Γ} : has_type_proc Γ Expr.Process.nil
| ty_emit {Γ pe} : has_type_pop Γ pe → has_type_proc Γ (Expr.Process.emit pe)
| ty_par  {Γ P Q} : has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.par P Q)
| ty_seq  {Γ P Q} : has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.seq P Q)
| ty_if   {Γ b P Q} : has_type_b Γ b → has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.iff b P Q)
| ty_let  {Γ x e τ P} : has_type_a Γ e τ → has_type_proc (Context.mk (fun v =&gt; if v = x then some τ else Γ.vars v) (Γ.pvars)) P → has_type_proc Γ (Expr.Process.let_in x e P)
| ty_fix  {Γ X P} : has_type_proc (Context.mk Γ.vars (fun pv =&gt; if pv = X then some Type.ProcT else Γ.pvars pv)) P → has_type_proc Γ (Expr.Process.fixp X P)
| ty_pvar {Γ X} : Γ.pvars X = some Type.ProcT → has_type_proc Γ (Expr.Process.pvar X)

/-- Well-formedness for semantic PopParam objects. The definition can be strengthened
    with invariants like radius ≥ 0, amplitude regularity, etc. -/
def well_typed_pop (p : PopParam) : Prop :=
  -- e.g., radius nonnegative for all t
  (∀ t, 0 ≤ p.radius t)

/-- Well-typed configuration: process well-typed and all pops well-formed. -/
def well_typed_config (Γ : Context) (cfg : Config) : Prop :=
  has_type_proc Γ cfg.proc ∧ (cfg.pops.all (fun p =&gt; well_typed_pop p))

/-----------------------------------------------------------------------------
  Theorems: Preservation and Progress (statements + proof skeletons)
-------------------------------------------------------------------------------/

/-- Preservation (Subject reduction): one-step preservation. -/
theorem preservation
  (env : Env)
  {Γ : Context} {C C' : Config} {α : Label}
  (hwf : well_typed_config Γ C)
  (hst : step env C α C') :
  well_typed_config Γ C' :=
begin
  -- Proof idea:
  -- by induction on hst; invert the step constructor and use typing rules
  -- plus determinism / totality of eval_* for closed well-typed expressions.
  match hst with
  | step.pop_emit he =&gt;
    -- process reduces from emit pe to nil; pops appended with p.
    -- show p satisfies well_typed_pop using typing of pe and evaluator soundness.
    admit
  | step.seq_left h =&gt; admit
  | step.seq_complete =&gt; admit
  | step.par_left h =&gt; admit
  | step.par_right h =&gt; admit
  | step.if_true h =&gt; admit
  | step.if_false h =&gt; admit
  | step.let_step hev =&gt; admit
  | step.fix_step =&gt; admit
  | step.cong_mod h1 h2 h3 =&gt; admit
  end
end

/-- Progress: closed, well-typed configurations are not stuck (modulo nil). -/
theorem progress
  (env : Env)
  {Γ : Context} {C : Config}
  (hwf : well_typed_config Γ C)
  (closed : True) -- closed_proc predicate omitted for brevity
  : (∃ P', cong_equiv C.proc P' ∧ P' = Expr.Process.nil) ∨ (∃ α C', step env C α C') :=
begin
  -- Proof idea:
  -- structural induction on typing derivation of C.proc. Use totality of eval_*.
  admit
end

/-----------------------------------------------------------------------------
  Remarks and next steps:

  • The file assumes <code>eval_aexpr</code>, <code>eval_bexpr</code>, <code>eval_popexpr</code> are available and
    total on well-typed closed inputs. In a full mechanization you implement
    those as deterministic functions (or relations proven functional/total).

  • <code>cong_equiv</code> is left abstract — implement as reflexive-transitive-symmetric
    closure of <code>cong</code>, or work with quotient types.

  • Continuous pop-store evolution (merge, dissipate, evolve_popstore) is kept
    separate from the discrete step relation. You can add hybrid semantics that
    interleave <code>step</code> and <code>evolve_popstore</code> transitions and state theorems such
    as <code>induced_field</code> determinism, energy bounds, locality, etc.

  • If you want, I can now produce a runnable Lean 4 file that compiles (with
    <code>sorry</code> for proofs) or start fleshing out proofs for either preservation or
