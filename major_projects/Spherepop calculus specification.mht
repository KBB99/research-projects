.50176 4.49805 8.50159Z"></path><path d="M10.0003 8.50159C10.8276 8.50176 11.4982 9.17239 11.4984 9.99963C11.4984 10.827 10.8277 11.4985 10.0003 11.4987C9.17283 11.4987 8.50131 10.8271 8.50131 9.99963C8.50149 9.17228 9.17294 8.50159 10.0003 8.50159Z"></path></svg></button></div></div></div></div></article><article class="text-token-text-primary w-full focus:outline-none [--shadow-height:45px] has-data-writing-block:pointer-events-none has-data-writing-block:-mt-(--shadow-height) has-data-writing-block:pt-(--shadow-height) [&amp;:has([data-writing-block])&gt;*]:pointer-events-auto scroll-mt-(--header-height)" tabindex="-1" dir="auto" data-turn-id="bbb2123e-0a2b-4ac9-abaa-1f53135cf6e8" data-testid="conversation-turn-13" data-scroll-anchor="false" data-turn="user"><h5 class="sr-only">You said:</h5><div class="text-base my-auto mx-auto pt-12 [--thread-content-margin:--spacing(4)] thread-sm:[--thread-content-margin:--spacing(6)] thread-lg:[--thread-content-margin:--spacing(16)] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] thread-lg:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col" tabindex="-1"><div class="flex max-w-full flex-col grow"><div data-message-author-role="user" data-message-id="bbb2123e-0a2b-4ac9-abaa-1f53135cf6e8" dir="auto" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden items-end rtl:items-start"><div class="user-message-bubble-color corner-superellipse/1.1 relative rounded-[18px] px-4 py-1.5 data-[multiline]:py-3 max-w-[var(--user-chat-width,70%)]" data-multiline=""><div class="whitespace-pre-wrap">-- SpherePop.Core — Minimal core calculus for SpherePop
-- Purpose: a compact, normalized core file containing
--   * syntax (minimal)
--   * structural congruence (with cong_equiv closure)
--   * small-step semantics (reduction modulo cong_equiv via step_mod)
--   * multi-step closure (step_star)
--   * simple typing judgments
--   * statements of Preservation and Progress

universe u

/-- Primitive semantic domains (abstract). -/
constant Point : Type u
constant Time  : Type u

/-- Pop parameter record (semantic object). -/
structure PopParam :=
(center : Point)
(start  : Time)
(radius : Time → ℝ)
(amp    : Time → ℝ)
(mode   : Type u) -- keep Mode abstract in core

/-- Finite multiset representation (list). -/
def PopStore := List PopParam

namespace Expr

constant Var  : Type u
constant PVar : Type u

inductive AExpr : Type u
| var  : Var → AExpr
| real : ℝ → AExpr
| add  : AExpr → AExpr → AExpr

inductive BExpr : Type u
| eq : AExpr → AExpr → BExpr

/-- Pop expression is a minimal tuple of identifiers/exprs. -/
structure PopExpr :=
(center_e : AExpr)
(t0_e     : AExpr)
(rfun_e   : AExpr) -- simplified for core
(amp_e    : AExpr)
(mode_e   : AExpr)

/-- Core process syntax. -/
inductive Process : Type u
| nil    : Process
| emit   : PopExpr → Process            -- pop(PopExpr)
| par    : Process → Process → Process  -- P | Q
| seq    : Process → Process → Process  -- P ; Q
| let_in : Var → AExpr → Process → Process
| iff    : BExpr → Process → Process → Process
| fixp   : PVar → Process → Process
| pvar   : PVar → Process

end Expr

open Expr

/-----------------------------------------------------------------------------
  Substitution and evaluation stubs (abstracted in core)
-------------------------------------------------------------------------------/

constant Value : Type u
constant Env : Type u
constant subst_proc : Expr.Var → Value → Expr.Process → Expr.Process
constant subst_pvar : Expr.PVar → Expr.Process → Expr.Process → Expr.Process

/-----------------------------------------------------------------------------
  Structural congruence (small set) and its equivalence closure
-------------------------------------------------------------------------------/

inductive cong : Expr.Process → Expr.Process → Prop
| par_comm  {P Q} : cong (Process.par P Q) (Process.par Q P)
| par_assoc {P Q R} : cong (Process.par (Process.par P Q) R) (Process.par P (Process.par Q R))
| par_id    {P} : cong (Process.par P Process.nil) P
| seq_assoc {P Q R} : cong (Process.seq (Process.seq P Q) R) (Process.seq P (Process.seq Q R))
| seq_id    {P} : cong (Process.seq Process.nil P) P
| fix_unfold {X P} : cong (Process.fixp X P) (subst_pvar X (Process.fixp X P) P)

inductive cong_equiv : Expr.Process → Expr.Process → Prop
| base {P Q} : cong P Q → cong_equiv P Q
| refl {P}    : cong_equiv P P
| symm {P Q}  : cong_equiv P Q → cong_equiv Q P
| trans {P Q R} : cong_equiv P Q → cong_equiv Q R → cong_equiv P R

/-----------------------------------------------------------------------------
  Small-step semantics (no cong_mod inside); define step_mod separately.
-------------------------------------------------------------------------------/

inductive Label : Type u
| tau : Label
| emit_lbl : PopParam → Label

structure Config :=
(proc : Expr.Process)
(pops : PopStore)

/-- Basic step relation on representative processes (not modulo cong). -/
inductive step (env : Env) : Config → Label → Config → Prop
| pop_emit {pe Π p} :
    -- assume eval_popexpr env pe = some p (left abstract)
    -- represented here as an axiom-like premise expressed by <code>eval_popexpr_holds</code>.
    (eval_popexpr_holds env pe p) →
    step env ⟨Process.emit pe, Π⟩ (Label.emit_lbl p) ⟨Process.nil, Π ++ [p]⟩
| seq_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Process.seq P Q, Π⟩ α ⟨Process.seq P' Q, Π'⟩
| seq_complete {Q Π} :
    step env ⟨Process.seq Process.nil Q, Π⟩ Label.tau ⟨Q, Π⟩
| par_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Process.par P Q, Π⟩ α ⟨Process.par P' Q, Π'⟩
| par_right {P Q Q' Π Π' α} :
    step env ⟨Q, Π⟩ α ⟨Q', Π'⟩ →
    step env ⟨Process.par P Q, Π⟩ α ⟨Process.par P Q', Π'⟩
| if_true {b P Q Π} :
    (eval_bexpr_true env b) →
    step env ⟨Process.iff b P Q, Π⟩ Label.tau ⟨P, Π⟩
| if_false {b P Q Π} :
    (eval_bexpr_false env b) →
    step env ⟨Process.iff b P Q, Π⟩ Label.tau ⟨Q, Π⟩
| let_step {x e P Π v} :
    (eval_aexpr_val env e v) →
    step env ⟨Process.let_in x e P, Π⟩ Label.tau ⟨(subst_proc x v P), Π⟩
| fix_step {X P Π} :
    step env ⟨Process.fixp X P, Π⟩ Label.tau ⟨(subst_pvar X (Process.fixp X P) P), Π⟩

/-- Predicates representing total deterministic evaluators on well-typed inputs.
    In the Core file they are abstract assumptions. -/
constant eval_popexpr_holds : Env → Expr.PopExpr → PopParam → Prop
constant eval_bexpr_true  : Env → Expr.BExpr → Prop
constant eval_bexpr_false : Env → Expr.BExpr → Prop
constant eval_aexpr_val   : Env → Expr.AExpr → Value → Prop

/-- Reduction modulo cong_equiv: step_mod relates configs that can reduce up to
    congruence on the left and right. This avoids embedding cong into constructors. -/
inductive step_mod (env : Env) : Config → Label → Config → Prop
| mk {P1 P2 P1' P2' Π Π' α} :
    cong_equiv P1 P2 →
    step env ⟨P2, Π⟩ α ⟨P2', Π'⟩ →
    cong_equiv P2' P1' →
    step_mod env ⟨P1, Π⟩ α ⟨P1', Π'⟩

/-----------------------------------------------------------------------------
  Reflexive–transitive closure (step_star) of step_mod (unlabelled). -/
inductive step_star (env : Env) : Config → Config → Prop
| refl {C} : step_star env C C
| trans {C1 C2 C3 α} : step_mod env C1 α C2 → step_star env C2 C3 → step_star env C1 C3

/-----------------------------------------------------------------------------
  Simple typing (core): Context, a few typing rules for processes, and well-typed
  configurations. This core typing is intentionally minimal.
-------------------------------------------------------------------------------/

inductive Type : Type u
| Real : Type
| ProcT : Type
| PopParamT : Type

structure Context :=
(vars : Expr.Var → Option Type)
(pvars : Expr.PVar → Option Type)

inductive has_type_a : Context → Expr.AExpr → Type → Prop
| ty_real {Γ r} : has_type_a Γ (Expr.AExpr.real r) Type.Real

inductive has_type_b : Context → Expr.BExpr → Prop
| ty_eq {Γ e1 e2} : has_type_a Γ e1 Type.Real → has_type_a Γ e2 Type.Real → has_type_b Γ (Expr.BExpr.eq e1 e2)

inductive has_type_pop : Context → Expr.PopExpr → Prop
| pop_core {Γ} : has_type_pop Γ (Expr.PopExpr.mk (Expr.AExpr.var (Classical.arbitrary _)) (Expr.AExpr.real 0) (Expr.AExpr.real 0) (Expr.AExpr.real 0) (Expr.AExpr.real 0))

inductive has_type_proc : Context → Expr.Process → Prop
| ty_nil {Γ} : has_type_proc Γ Expr.Process.nil
| ty_emit {Γ pe} : has_type_pop Γ pe → has_type_proc Γ (Expr.Process.emit pe)
| ty_par  {Γ P Q} : has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.par P Q)
| ty_seq  {Γ P Q} : has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.seq P Q)
| ty_if   {Γ b P Q} : has_type_b Γ b → has_type_proc Γ P → has_type_proc Γ Q → has_type_proc Γ (Expr.Process.iff b P Q)
| ty_let  {Γ x e P} : has_type_a Γ e Type.Real → has_type_proc Γ P → has_type_proc Γ (Expr.Process.let_in x e P)
| ty_fix  {Γ X P} : has_type_proc (Context.mk Γ.vars (fun pv =&gt; if pv = X then some Type.ProcT else Γ.pvars pv)) P → has_type_proc Γ (Expr.Process.fixp X P)
| ty_pvar {Γ X} : Γ.pvars X = some Type.ProcT → has_type_proc Γ (Expr.Process.pvar X)

/-- Well-formedness predicate for PopParam values (core invariant). -/
def well_typed_pop (p : PopParam) : Prop :=
  ∀ t, 0 ≤ p.radius t

/-- Well-typed configuration: process well-typed and all pops well-formed. -/
def well_typed_config (Γ : Context) (cfg : Config) : Prop :=
  has_type_proc Γ cfg.proc ∧ cfg.pops.all (fun p =&gt; well_typed_pop p)

/-----------------------------------------------------------------------------
  The central meta-theorems (statements only) for the core calculus.
-------------------------------------------------------------------------------/

/-- Preservation (subject reduction) for one step_mod. -/
theorem preservation
  (env : Env)
  {Γ : Context} {C C' : Config} {α : Label}
  (hwf : well_typed_config Γ C)
  (hst : step_mod env C α C') :
  well_typed_config Γ C' :=
begin
  -- proof omitted in Core; to be filled in a proof file
  admit
end

/-- Progress: closed, well-typed configurations either are nil (mod cong) or can step. -/
theorem progress
  (env : Env)
  {Γ : Context} {C : Config}
  (hwf : well_typed_config Γ C)
  (closed : True) :
  (∃ P', cong_equiv C.proc P' ∧ P' = Expr.Process.nil) ∨ (∃ α C', step_mod env C α C') :=
begin
  admit
end

/-----------------------------------------------------------------------------
  Notes:
  - The Core file intentionally leaves evaluators and many implementation details
    abstract (as predicates/assumptions). This keeps the core small and focused
    on the calculus' algebraic structure.

  - Next steps usually are: (1) implement evaluators in a separate file,
    (2) implement <code>subst_proc</code> / <code>subst_pvar</code> and decidable equality for Var / PVar,
    (3) begin mechanized proofs of preservation and progress.

-- End of SpherePop.Core
