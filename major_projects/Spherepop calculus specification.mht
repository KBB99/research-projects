  (env : Env)
  {Γ : Context} {C C' : Config} {α : Label}
  (hwf : well_typed_config Γ C)
  (hst : step env C α C') :
  well_typed_config Γ C' :=
begin
  -- proof outline:
  -- 1. destruct C = ⟨P, Π⟩, C' = ⟨P', Π'⟩
  -- 2. invert hst on each constructor (pop_emit, seq_left, etc.)
  -- 3. use typing rules and Option A’s soundness of eval_* to show types preserved.
