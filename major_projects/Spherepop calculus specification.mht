constant PVar : Type u

inductive AExpr : Type u
| var  : Var → AExpr
| real : ℝ → AExpr
| add  : AExpr → AExpr → AExpr

inductive BExpr : Type u
| eq : AExpr → AExpr → BExpr

structure PopExpr :=
(center_e : AExpr)
(t0_e     : AExpr)
(rfun_e   : AExpr)
(amp_e    : AExpr)
(mode_e   : AExpr)

inductive Process : Type u
| nil    : Process
| emit   : PopExpr → Process
| par    : Process → Process → Process
| seq    : Process → Process → Process
| let_in : Var → AExpr → Process → Process
| iff    : BExpr → Process → Process → Process
| fixp   : PVar → Process → Process
| pvar   : PVar → Process

end Expr

open Expr

/===============================
  Substitution &amp; Evaluators (abstract)
================================/

constant Value : Type u
constant Env   : Type u

constant subst_proc : Expr.Var → Value → Expr.Process → Expr.Process
constant subst_pvar : Expr.PVar → Expr.Process → Expr.Process → Expr.Process

constant eval_popexpr_holds : Env → Expr.PopExpr → PopParam → Prop
constant eval_bexpr_true    : Env → Expr.BExpr → Prop
constant eval_bexpr_false   : Env → Expr.BExpr → Prop
constant eval_aexpr_val     : Env → Expr.AExpr → Value → Prop

/===============================
  Structural Congruence
================================/

inductive cong : Expr.Process → Expr.Process → Prop
| par_comm {P Q} :
    cong (Process.par P Q) (Process.par Q P)
| par_assoc {P Q R} :
    cong (Process.par (Process.par P Q) R)
         (Process.par P (Process.par Q R))
| par_id {P} :
    cong (Process.par P Process.nil) P
| seq_assoc {P Q R} :
    cong (Process.seq (Process.seq P Q) R)
         (Process.seq P (Process.seq Q R))
| seq_id {P} :
    cong (Process.seq Process.nil P) P
| fix_unfold {X P} :
    cong (Process.fixp X P)
         (subst_pvar X (Process.fixp X P) P)

/-- Equivalence closure of structural congruence. -/
inductive cong_equiv : Expr.Process → Expr.Process → Prop
| base {P Q} : cong P Q → cong_equiv P Q
| refl {P}   : cong_equiv P P
| symm {P Q} : cong_equiv P Q → cong_equiv Q P
| trans {P Q R} :
    cong_equiv P Q → cong_equiv Q R → cong_equiv P R

/===============================
  Config &amp; Small-step Semantics
================================/

inductive Label : Type u
| tau : Label
| emit_lbl : PopParam → Label

structure Config :=
(proc : Expr.Process)
(pops : PopStore)

/-- Base reduction relation (no congruence). -/
inductive step (env : Env) : Config → Label → Config → Prop
| pop_emit {pe Π p} :
    eval_popexpr_holds env pe p →
    step env ⟨Process.emit pe, Π⟩ (Label.emit_lbl p)
              ⟨Process.nil, Π ++ [p]⟩

| seq_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Process.seq P Q, Π⟩ α
              ⟨Process.seq P' Q, Π'⟩

| seq_complete {Q Π} :
    step env ⟨Process.seq Process.nil Q, Π⟩ Label.tau
              ⟨Q, Π⟩

| par_left {P P' Q Π Π' α} :
    step env ⟨P, Π⟩ α ⟨P', Π'⟩ →
    step env ⟨Process.par P Q, Π⟩ α
              ⟨Process.par P' Q, Π'⟩

| par_right {P Q Q' Π Π' α} :
    step env ⟨Q, Π⟩ α ⟨Q', Π'⟩ →
    step env ⟨Process.par P Q, Π⟩ α
              ⟨Process.par P Q', Π'⟩

| if_true {b P Q Π} :
    eval_bexpr_true env b →
    step env ⟨Process.iff b P Q, Π⟩ Label.tau
              ⟨P, Π⟩

| if_false {b P Q Π} :
    eval_bexpr_false env b →
    step env ⟨Process.iff b P Q, Π⟩ Label.tau
              ⟨Q, Π⟩

| let_step {x e P Π v} :
    eval_aexpr_val env e v →
    step env ⟨Process.let_in x e P, Π⟩ Label.tau
              ⟨subst_proc x v P, Π⟩

| fix_step {X P Π} :
    step env ⟨Process.fixp X P, Π⟩ Label.tau
              ⟨subst_pvar X (Process.fixp X P) P, Π⟩

/-- Step modulo structural congruence. -/
inductive step_mod (env : Env) : Config → Label → Config → Prop
| mk {P1 P2 P2' P1' Π Π' α} :
    cong_equiv P1 P2 →
    step env ⟨P2, Π⟩ α ⟨P2', Π'⟩ →
    cong_equiv P2' P1' →
    step_mod env ⟨P1, Π⟩ α ⟨P1', Π'⟩

/-- Reflexive–transitive closure. -/
inductive step_star (env : Env) : Config → Config → Prop
| refl {C} : step_star env C C
| trans {C1 C2 C3 α} :
    step_mod env C1 α C2 →
    step_star env C2 C3 →
    step_star env C1 C3

/===============================
  Typing
================================/

inductive Type : Type u
| Real : Type
| ProcT : Type
| PopParamT : Type

structure Context :=
(vars : Expr.Var → Option Type)
(pvars : Expr.PVar → Option Type)

inductive has_type_a : Context → Expr.AExpr → Type → Prop
| ty_real {Γ r} :
    has_type_a Γ (Expr.AExpr.real r) Type.Real

inductive has_type_b : Context → Expr.BExpr → Prop
| ty_eq {Γ e1 e2} :
    has_type_a Γ e1 Type.Real →
    has_type_a Γ e2 Type.Real →
    has_type_b Γ (Expr.BExpr.eq e1 e2)

inductive has_type_pop : Context → Expr.PopExpr → Prop
| pop {Γ c t r a m} :
    has_type_a Γ c Type.Real →
    has_type_a Γ t Type.Real →
    has_type_a Γ r Type.Real →
    has_type_a Γ a Type.Real →
    has_type_a Γ m Type.Real →
    has_type_pop Γ (Expr.PopExpr.mk c t r a m)

inductive has_type_proc : Context → Expr.Process → Prop
| ty_nil {Γ} :
    has_type_proc Γ Expr.Process.nil
| ty_emit {Γ pe} :
    has_type_pop Γ pe →
    has_type_proc Γ (Expr.Process.emit pe)
| ty_par {Γ P Q} :
    has_type_proc Γ P → has_type_proc Γ Q →
    has_type_proc Γ (Expr.Process.par P Q)
| ty_seq {Γ P Q} :
    has_type_proc Γ P → has_type_proc Γ Q →
    has_type_proc Γ (Expr.Process.seq P Q)
| ty_if {Γ b P Q} :
    has_type_b Γ b →
    has_type_proc Γ P →
    has_type_proc Γ Q →
    has_type_proc Γ (Expr.Process.iff b P Q)
| ty_let {Γ x e P} :
    has_type_a Γ e Type.Real →
    has_type_proc Γ P →
    has_type_proc Γ (Expr.Process.let_in x e P)
| ty_fix {Γ X P} :
    has_type_proc (Context.mk Γ.vars (fun pv =&gt; if pv = X then some Type.ProcT else Γ.pvars pv)) P →
    has_type_proc Γ (Expr.Process.fixp X P)
| ty_pvar {Γ X} :
    Γ.pvars X = some Type.ProcT →
    has_type_proc Γ (Expr.Process.pvar X)

/-- Semantic well-formedness of PopParam. -/
def well_typed_pop (p : PopParam) : Prop :=
  ∀ t, 0 ≤ p.radius t

/-- Well-typed configuration: process well-typed and all pops well-formed. -/
def well_typed_config (Γ : Context) (cfg : Config) : Prop :=
  has_type_proc Γ cfg.proc ∧ cfg.pops.all (fun p =&gt; well_typed_pop p)

/===============================
  Meta-Theorems (statements only)
================================/

theorem preservation
  (env : Env)
  {Γ : Context} {C C' : Config} {α : Label}
  (hwf : well_typed_config Γ C)
  (hst : step_mod env C α C') :
  well_typed_config Γ C' :=
by admit

theorem progress
  (env : Env)
  {Γ : Context} {C : Config}
  (hwf : well_typed_config Γ C)
  (closed : True) :
  (∃ P', cong_equiv C.proc P' ∧ P' = Expr.Process.nil)
  ∨ (∃ α C', step_mod env C α) :=
by admit
