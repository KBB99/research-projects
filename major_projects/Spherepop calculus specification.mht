  match eval_aexpr env e with
  | some (Value.real a) := some (λ t, a)
  | _ := none
  end
| env (Expr.AmpExpr.decay eλ) :=
  match eval_aexpr env eλ with
  | some (Value.real λr) := some (λ t, Real.exp (-λr * t))
  | _ := none
