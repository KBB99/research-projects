<span class="katex-display"><span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML" display="block"><semantics><mrow><mo mathvariant="normal" lspace="0em" rspace="0em">⟦</mo><mtext>emit</mtext><mo stretchy="false">(</mo><mi>p</mi><mo stretchy="false">)</mo><mo mathvariant="normal" lspace="0em" rspace="0em">⟧</mo><mo>=</mo><mi>p</mi></mrow><annotation encoding="application/x-tex">\llbracket \text{emit}(p) \rrbracket = p</annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 1em; vertical-align: -0.25em;"></span><span class="mopen"><span class="mopen">[</span><span class="mspace" style="margin-right: -0.1778em;"></span><span class="mopen">[</span></span><span class="mord text"><span class="mord">emit</span></span><span class="mopen">(</span><span class="mord mathnormal">p</span><span class="mclose">)</span><span class="mclose"><span class="mclose">]</span><span class="mspace" style="margin-right: -0.1778em;"></span><span class="mclose">]</span></span><span class="mspace" style="margin-right: 0.2778em;"></span><span class="mrel">=</span><span class="mspace" style="margin-right: 0.2778em;"></span></span><span class="base"><span class="strut" style="height: 0.625em; vertical-align: -0.1944em;"></span><span class="mord mathnormal">p</span></span></span></span></span>
<h3 data-start="3920" data-end="3933">parallel:</h3>
<span class="katex-display"><span class="katex"><span class="katex-mathml"><math xmlns="http://www.w3.org/1998/Math/MathML" display="block"><semantics><mrow><mo mathvariant="normal" lspace="0em" rspace="0em">⟦</mo><msub><mi>P</mi><mn>1</mn></msub><mo>∣</mo><msub><mi>P</mi><mn>2</mn></msub><mo mathvariant="normal" lspace="0em" rspace="0em">⟧</mo><mo>=</mo><mo mathvariant="normal" lspace="0em" rspace="0em">⟦</mo><msub><mi>P</mi><mn>1</mn></msub><mo mathvariant="normal" lspace="0em" rspace="0em">⟧</mo><mo>⊗</mo><mo mathvariant="normal" lspace="0em" rspace="0em">⟦</mo><msub><mi>P</mi><mn>2</mn></msub><mo mathvariant="normal" lspace="0em" rspace="0em">⟧</mo></mrow><annotation encoding="application/x-tex">\llbracket P_1 \mid P_2 \rrbracket = \llbracket P_1 \rrbracket \otimes \llbracket P_2 \rrbracket</annotation></semantics></math></span><span class="katex-html" aria-hidden="true"><span class="base"><span class="strut" style="height: 1em; vertical-align: -0.25em;"></span><span class="mopen"><span class="mopen">[</span><span class="mspace" style="margin-right: -0.1778em;"></span><span class="mopen">[</span></span><span class="mord"><span class="mord mathnormal" style="margin-right: 0.13889em;">P</span><span class="msupsub"><span class="vlist-t vlist-t2"><span class="vlist-r"><span class="vlist" style="height: 0.3011em;"><span style="top: -2.55em; margin-left: -0.1389em; margin-right: 0.05em;"><span class="pstrut" style="height: 2.7em;"></span><span class="sizing reset-size6 size3 mtight"><span class="mord mtight">1</span></span></span></span><span class="vlist-s">​</span></span><span class="vlist-r"><span class="vlist" style="height: 0.15em;"><span></span></span></span></span></span></span><span class="mspace" style="margin-right: 0.2778em;"></span><span class="mrel">∣</span><span class="mspace" style="margin-right: 0.2778em;"></span></span><span class="base"><span class="strut" style="height: 1em; vertical-align: -0.25em;"></span><span class="mord"><span class="mord mathn